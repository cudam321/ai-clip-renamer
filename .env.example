# Dropbox Settings
DROPBOX_APP_KEY="your_dropbox_app_key"
DROPBOX_APP_SECRET="your_dropbox_app_secret"
DROPBOX_REFRESH_TOKEN="your_dropbox_refresh_token"
DROPBOX_WATCH_FOLDER="/Raw_Ingest"

# OpenAI Settings (For Whisper Audio)
OPENAI_API_KEY="your_openai_api_key"

# OpenRouter Settings (For Vision & Text Synthesis)
OPENROUTER_API_KEY="your_openrouter_api_key"
OPENROUTER_MODEL="openai/gpt-4o"

# Creator / context description fed to the AI to tailor scene descriptions.
CREATOR_CONTEXT="an independent content creator"

# Categories the AI may route clips into (comma-separated, filesystem-safe names).
# Uncomment to override the built-in defaults.
# CATEGORIES="highlights,interview,tutorial,event,lifestyle,product,behind_the_scenes,funny,other"

# Script Configuration
POLL_INTERVAL=60
FRAME_INTERVAL=3
TEMP_DIR="/tmp/ai_renamer"
